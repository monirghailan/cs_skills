{
  "name": "cs_skills",
  "version": "1.1.0",
  "description": "MCP server for browsing and installing Cursor skills from a shared registry.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cs_skills": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "skills/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "build-registry": "node --loader ts-node/esm scripts/build-registry.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cursor",
    "skills",
    "registry",
    "ai",
    "developer-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
